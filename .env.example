# --- Base de données ---
# MongoDB Atlas (prod) ou local (dev)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/coach-ia

# --- Serveur ---
# Render injecte PORT automatiquement. En local, 3000 par défaut.
PORT=3000

# --- Ollama ---
# En DEV (app + Ollama sur ta machine) :
#   OLLAMA_URL=http://localhost:11434
# En PROD (app sur Render, Ollama exposé via tunnel Cloudflare) :
#   OLLAMA_URL=https://ollama.ton-domaine.com
OLLAMA_URL=http://localhost:11434

# Modèle Ollama installé (ex: llama3.1, qwen2.5, mistral, phi3...)
OLLAMA_MODEL=llama3.1
